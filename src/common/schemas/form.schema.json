{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ceylinco-forms.com/schemas/form.schema.json",
  "title": "Ceylinco Forms Schema",
  "description": "JSON schema for Ceylinco form definitions",
  "type": "object",
  "required": ["metadata", "submission", "fields", "layout"],
  "properties": {
    "metadata": {
      "$ref": "#/definitions/IFormMetadata"
    },
    "prefilledFields": {
      "type": "array",
      "description": "Field keys that are prefilled using OTP service",
      "items": {
        "type": "string"
      }
    },
    "submission": {
      "$ref": "#/definitions/IFormSubmission"
    },
    "fields": {
      "type": "object",
      "description": "Form field definitions",
      "additionalProperties": {
        "$ref": "#/definitions/IFormField"
      }
    },
    "layout": {
      "type": "array",
      "description": "Layout items defining the order and structure of form elements",
      "items": {
        "$ref": "#/definitions/IFormLayoutItem"
      }
    },
    "localization": {
      "type": "object",
      "description": "Multi-language translations",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        }
      },
      "patternProperties": {
        "^(en|si|ta)$": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  },
  "definitions": {
    "IFormMetadata": {
      "type": "object",
      "required": [
        "formVersion",
        "formTitle",
        "formDescription",
        "availableLocales"
      ],
      "anyOf": [{ "required": ["otp"] }, { "required": ["otpRequired"] }],
      "properties": {
        "formVersion": {
          "type": "integer",
          "enum": [1],
          "description": "Form version (currently only version 1 is supported)"
        },
        "formTitle": {
          "type": "string",
          "description": "Display title for the form"
        },
        "formDescription": {
          "type": "string",
          "description": "Display description for the form"
        },
        "showFormHeader": {
          "type": "boolean",
          "description": "Whether to show form header with title and description (default: true)",
          "default": true
        },
        "availableLocales": {
          "type": "array",
          "description": "Available locales for the form",
          "items": {
            "type": "string",
            "enum": ["en", "si", "ta"]
          },
          "minItems": 1
        },
        "defaultLocale": {
          "type": "string",
          "enum": ["en", "si", "ta"],
          "description": "Default locale (if left blank, 'en' is used)"
        },
        "otp": {
          "type": "boolean",
          "description": "Whether OTP is required for the form. If enabled, form can use $otp for its onFormOpen, fields as a variable."
        },
        "otpRequired": {
          "type": "boolean",
          "description": "Deprecated: Use 'otp' instead. Whether OTP verification is required"
        }
      }
    },
    "IFormSubmission": {
      "type": "object",
      "required": ["endpoint", "method", "requiresAccessToken"],
      "properties": {
        "endpoint": {
          "type": "string",
          "description": "API endpoint for form submission"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "DELETE", "PATCH"],
          "description": "HTTP method for form submission"
        },
        "requiresAccessToken": {
          "type": "boolean",
          "description": "Whether authentication token is required for submission"
        }
      }
    },
    "IFormField": {
      "oneOf": [
        { "$ref": "#/definitions/IFormSelectField" },
        { "$ref": "#/definitions/IFormRadioGroupField" },
        { "$ref": "#/definitions/IFormCheckboxGroupField" },
        { "$ref": "#/definitions/IFormFileField" },
        { "$ref": "#/definitions/IFormCheckboxField" },
        { "$ref": "#/definitions/IFormTextareaField" },
        { "$ref": "#/definitions/IFormAgeField" },
        { "$ref": "#/definitions/IFormFieldBase" }
      ]
    },
    "IFormFieldBase": {
      "type": "object",
      "required": ["type", "label"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "text",
            "number",
            "email",
            "password",
            "date",
            "time",
            "datetime-local",
            "checkbox",
            "radio-group",
            "checkbox-group",
            "select",
            "textarea",
            "file",
            "url",
            "tel",
            "age"
          ],
          "description": "Field type"
        },
        "label": {
          "type": "string",
          "description": "Field label"
        },
        "required": {
          "type": "boolean",
          "description": "Whether the field is required",
          "default": false
        },
        "placeholder": {
          "type": "string",
          "description": "Placeholder text for the field"
        },
        "description": {
          "type": "string",
          "description": "Help text or description for the field"
        },
        "defaultValue": {
          "type": "string",
          "description": "Default value for the field"
        },
        "validation": {
          "$ref": "#/definitions/IFormFieldValidation"
        },
        "dependencies": {
          "type": "object",
          "description": "Conditional fields that depend on this field",
          "additionalProperties": {
            "$ref": "#/definitions/IFormField"
          }
        },
        "conditionalOptions": {
          "$ref": "#/definitions/IFormConditionalFieldOptions"
        }
      }
    },
    "IFormTextareaField": {
      "allOf": [
        { "$ref": "#/definitions/IFormFieldBase" },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "textarea"
            },
            "rows": {
              "type": "integer",
              "description": "Number of visible rows for the textarea",
              "minimum": 1
            }
          }
        }
      ]
    },
    "IFormCheckboxField": {
      "allOf": [
        { "$ref": "#/definitions/IFormFieldBase" },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "checkbox"
            },
            "checked": {
              "type": "boolean",
              "description": "Default checked state",
              "default": false
            }
          }
        }
      ]
    },
    "IFormSelectField": {
      "allOf": [
        { "$ref": "#/definitions/IFormFieldBase" },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "select"
            },
            "options": {
              "type": "object",
              "description": "Select options as key-value pairs",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "IFormRadioGroupField": {
      "allOf": [
        { "$ref": "#/definitions/IFormFieldBase" },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "radio-group"
            },
            "orientation": {
              "type": "string",
              "enum": ["vertical", "horizontal"],
              "description": "Orientation of radio buttons",
              "default": "vertical"
            },
            "options": {
              "type": "object",
              "description": "Radio group options as key-value pairs",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "IFormCheckboxGroupField": {
      "allOf": [
        { "$ref": "#/definitions/IFormFieldBase" },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "checkbox-group"
            },
            "options": {
              "type": "object",
              "description": "Checkbox group options as key-value pairs",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "IFormFileField": {
      "allOf": [
        { "$ref": "#/definitions/IFormFieldBase" },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "file"
            },
            "fileOptions": {
              "$ref": "#/definitions/IFormFileOptions"
            }
          }
        }
      ]
    },
    "IFormAgeField": {
      "allOf": [
        { "$ref": "#/definitions/IFormFieldBase" },
        {
          "type": "object",
          "required": ["dateOfBirthField"],
          "properties": {
            "type": {
              "const": "age"
            },
            "dateOfBirthField": {
              "type": "string",
              "description": "Name of the field containing the date of birth"
            },
            "format": {
              "type": "string",
              "description": "Format string for age display (e.g., '{y} years, {m} months, {d} days'). Placeholders: {y} for years, {m} for months, {d} for days. Default: '{y}'"
            },
            "toDate": {
              "type": "string",
              "description": "Target date to calculate age up to (supports variables like {{$today}}). Defaults to current date if not specified"
            }
          }
        }
      ]
    },
    "IFormFileOptions": {
      "type": "object",
      "properties": {
        "maxSize": {
          "type": "integer",
          "description": "Maximum file size in bytes (e.g., 5242880 for 5MB)",
          "minimum": 1
        },
        "allowedExtensions": {
          "type": "array",
          "description": "Allowed file extensions (without dots, e.g., ['pdf', 'jpg', 'png'])",
          "items": {
            "type": "string"
          }
        },
        "multiple": {
          "type": "boolean",
          "description": "Whether multiple files are allowed",
          "default": false
        }
      }
    },
    "IFormFieldValidation": {
      "type": "object",
      "properties": {
        "maxLength": {
          "type": "integer",
          "description": "Maximum length for text fields",
          "minimum": 1
        },
        "minLength": {
          "type": "integer",
          "description": "Minimum length for text fields",
          "minimum": 0
        },
        "min": {
          "type": "number",
          "description": "Minimum value for number fields"
        },
        "max": {
          "type": "number",
          "description": "Maximum value for number fields"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for validation"
        }
      }
    },
    "IFormConditionalFieldOptions": {
      "type": "object",
      "required": ["operator", "value"],
      "properties": {
        "operator": {
          "type": "string",
          "enum": [
            "eq",
            "neq",
            "gt",
            "gte",
            "lt",
            "lte",
            "contains",
            "notContains",
            "startsWith",
            "endsWith"
          ],
          "description": "Conditional operator"
        },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            {
              "type": "array",
              "items": { "type": "string" }
            },
            {
              "type": "array",
              "items": { "type": "number" }
            },
            {
              "type": "array",
              "items": { "type": "boolean" }
            }
          ],
          "description": "Value to compare against"
        }
      }
    },
    "IFormLayoutItem": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "Translation key for non-field items (e.g., headings, text, cards, submit)"
        },
        "align": {
          "type": "string",
          "enum": ["left", "center", "right", "justify"],
          "description": "Horizontal alignment"
        },
        "fontSize": {
          "type": "integer",
          "description": "Font size in pixels (auto-size if not set)",
          "minimum": 1
        },
        "margin": {
          "oneOf": [{ "type": "integer" }, { "type": "string" }],
          "description": "Margin in CSS shorthand, e.g. '10px 0 20px 0'"
        },
        "variant": {
          "type": "string",
          "enum": [
            "default",
            "destructive",
            "outline",
            "secondary",
            "ghost",
            "link"
          ],
          "description": "Button variant (for submit/reset buttons, defaults to 'default')"
        },
        "loadingText": {
          "type": "string",
          "description": "Text to show while submitting (for future use)"
        },
        "loadingTextKey": {
          "type": "string",
          "description": "Translation key for loading text (for future use)"
        },
        "items": {
          "type": "array",
          "description": "Nested layout items inside a card (only for 'card' layout items)",
          "items": {
            "$ref": "#/definitions/IFormLayoutItem"
          }
        },
        "columns": {
          "type": "array",
          "description": "Column items for a row (only for 'row' layout items)",
          "items": {
            "$ref": "#/definitions/IFormLayoutItem"
          }
        },
        "colspan": {
          "type": "integer",
          "description": "Column span for row column items",
          "minimum": 1
        },
        "field": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Field key reference (use field name as string, or true for field layout item)"
        },
        "h1": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Heading level 1 text"
        },
        "h2": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Heading level 2 text"
        },
        "h3": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Heading level 3 text"
        },
        "h4": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Heading level 4 text"
        },
        "h5": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Heading level 5 text"
        },
        "h6": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Heading level 6 text"
        },
        "text": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Text content (supports markdown)"
        },
        "spacer": {
          "oneOf": [{ "type": "integer" }, { "type": "boolean" }],
          "description": "Spacer height in pixels"
        },
        "divider": {
          "oneOf": [{ "type": "boolean" }, { "type": "string" }],
          "description": "Divider element"
        },
        "card": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Card label/title"
        },
        "row": {
          "oneOf": [{ "type": "integer" }, { "type": "boolean" }],
          "description": "Number of columns in the row"
        },
        "submit": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Submit button text"
        },
        "reset": {
          "oneOf": [{ "type": "string" }, { "type": "boolean" }],
          "description": "Reset button text"
        }
      },
      "oneOf": [
        {
          "required": ["field"]
        },
        {
          "required": ["h1"]
        },
        {
          "required": ["h2"]
        },
        {
          "required": ["h3"]
        },
        {
          "required": ["h4"]
        },
        {
          "required": ["h5"]
        },
        {
          "required": ["h6"]
        },
        {
          "required": ["text"]
        },
        {
          "required": ["spacer"]
        },
        {
          "required": ["divider"]
        },
        {
          "required": ["card"]
        },
        {
          "required": ["row"]
        },
        {
          "required": ["submit"]
        },
        {
          "required": ["reset"]
        }
      ]
    }
  }
}
