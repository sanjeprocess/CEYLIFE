{
  "metadata": {
    "formVersion": 1,
    "formTitle": "Life Insurance Proposal Form",
    "formDescription": "Apply for comprehensive life insurance cover with optional riders and beneficiary nominations.",
    "availableLocales": ["en", "si", "ta"],
    "otpRequired": true
  },
  "prefilledFields": ["fullName", "email", "mobile"],
  "submission": {
    "endpoint": "/api/forms/life-insurance",
    "method": "POST",
    "requiresAccessToken": true
  },
  "fields": {
    "fullName": {
      "type": "text",
      "label": "Full Name (as per NIC / Passport)",
      "required": true,
      "placeholder": "e.g. Perera A.B.C.",
      "description": "Please enter your full legal name including all middle names.",
      "defaultValue": "",
      "validation": {
        "minLength": 3,
        "maxLength": 100
      }
    },
    "dob": {
      "type": "date",
      "label": "Date of Birth",
      "required": true,
      "placeholder": "",
      "description": "You must be between 18 and 65 years of age to apply.",
      "defaultValue": "",
      "validation": {}
    },
    "gender": {
      "type": "radio-group",
      "label": "Gender",
      "required": true,
      "placeholder": "",
      "description": "",
      "defaultValue": "",
      "validation": {},
      "options": {
        "male": "Male",
        "female": "Female",
        "other": "Other / Prefer not to say"
      }
    },
    "maritalStatus": {
      "type": "select",
      "label": "Marital Status",
      "required": true,
      "placeholder": "Select marital status",
      "description": "",
      "defaultValue": "",
      "validation": {},
      "options": {
        "single": "Single",
        "married": "Married",
        "widowed": "Widowed",
        "divorced": "Divorced"
      }
    },
    "nationalId": {
      "type": "text",
      "label": "National ID / Passport No.",
      "required": true,
      "placeholder": "e.g. 123456789V",
      "description": "Enter your valid NIC or passport number.",
      "defaultValue": "",
      "validation": {
        "minLength": 5,
        "maxLength": 20,
        "pattern": "^[A-Za-z0-9]+$"
      }
    },
    "mobile": {
      "type": "tel",
      "label": "Mobile Number",
      "required": true,
      "placeholder": "e.g. +94 7X XXX XXXX",
      "description": "We will use this for OTP and policy communication.",
      "defaultValue": "",
      "validation": {
        "minLength": 9,
        "maxLength": 20,
        "pattern": "^[0-9+\\-\\s]+$"
      }
    },
    "email": {
      "type": "email",
      "label": "Email Address",
      "required": true,
      "placeholder": "you@example.com",
      "description": "Policy documents and notifications may be sent to this email.",
      "defaultValue": "",
      "validation": {
        "maxLength": 100
      }
    },
    "address": {
      "type": "textarea",
      "label": "Residential Address",
      "required": true,
      "placeholder": "House No, Street, City",
      "description": "",
      "defaultValue": "",
      "validation": {
        "minLength": 10,
        "maxLength": 300
      }
    },
    "occupation": {
      "type": "text",
      "label": "Occupation",
      "required": true,
      "placeholder": "e.g. Software Engineer",
      "description": "",
      "defaultValue": "",
      "validation": {
        "minLength": 2,
        "maxLength": 100
      }
    },
    "annualIncome": {
      "type": "number",
      "label": "Annual Income (LKR)",
      "required": true,
      "placeholder": "e.g. 2500000",
      "description": "Used only for risk assessment and underwriting.",
      "defaultValue": "",
      "validation": {
        "min": 0
      }
    },
    "smokerStatus": {
      "type": "radio-group",
      "label": "Do you smoke or use tobacco products?",
      "required": true,
      "placeholder": "",
      "description": "",
      "defaultValue": "",
      "validation": {},
      "options": {
        "non_smoker": "No, I do not",
        "occasional": "Yes, occasionally",
        "regular": "Yes, regularly"
      }
    },
    "alcoholUse": {
      "type": "radio-group",
      "label": "Do you consume alcohol?",
      "required": true,
      "placeholder": "",
      "description": "",
      "defaultValue": "",
      "validation": {},
      "options": {
        "none": "Never",
        "social": "Occasionally / Socially",
        "regular": "Regularly"
      }
    },
    "sumAssured": {
      "type": "number",
      "label": "Requested Sum Assured (LKR)",
      "required": true,
      "placeholder": "e.g. 10000000",
      "description": "Total life cover amount you are applying for.",
      "defaultValue": "",
      "validation": {
        "min": 1000000,
        "max": 50000000
      }
    },
    "policyTermYears": {
      "type": "number",
      "label": "Policy Term (Years)",
      "required": true,
      "placeholder": "e.g. 20",
      "description": "Number of years you want the cover to run.",
      "defaultValue": "",
      "validation": {
        "min": 5,
        "max": 40
      }
    },
    "premiumPaymentFrequency": {
      "type": "select",
      "label": "Premium Payment Frequency",
      "required": true,
      "placeholder": "Select frequency",
      "description": "",
      "defaultValue": "",
      "validation": {},
      "options": {
        "monthly": "Monthly",
        "quarterly": "Quarterly",
        "semi_annual": "Semi-Annual",
        "annual": "Annual"
      }
    },
    "addCriticalIllnessRider": {
      "type": "checkbox",
      "label": "Add Critical Illness Rider",
      "required": false,
      "placeholder": "",
      "description": "Provides additional payout on diagnosis of covered critical illnesses.",
      "defaultValue": "",
      "validation": {}
    },
    "addAccidentalDeathRider": {
      "type": "checkbox",
      "label": "Add Accidental Death Benefit Rider",
      "required": false,
      "placeholder": "",
      "description": "Additional benefit in the event of death due to accident.",
      "defaultValue": "",
      "validation": {}
    },
    "hasExistingPolicies": {
      "type": "radio-group",
      "label": "Do you have existing life insurance policies?",
      "required": true,
      "placeholder": "",
      "description": "",
      "defaultValue": "",
      "validation": {},
      "options": {
        "no": "No",
        "yes": "Yes"
      },
      "dependencies": {
        "existingPolicyDetails": {
          "type": "textarea",
          "label": "Existing Policy Details",
          "required": false,
          "placeholder": "Company, policy number, sum assured, commencement date, etc.",
          "description": "Provide details of all existing life insurance policies.",
          "defaultValue": "",
          "validation": {
            "maxLength": 1000
          },
          "conditionalOptions": {
            "operator": "eq",
            "value": "yes"
          }
        }
      }
    },
    "beneficiaryName": {
      "type": "text",
      "label": "Primary Beneficiary Name",
      "required": true,
      "placeholder": "e.g. Perera X.Y.Z.",
      "description": "",
      "defaultValue": "",
      "validation": {
        "minLength": 3,
        "maxLength": 100
      }
    },
    "beneficiaryRelationship": {
      "type": "select",
      "label": "Relationship to Beneficiary",
      "required": true,
      "placeholder": "Select relationship",
      "description": "",
      "defaultValue": "",
      "validation": {},
      "options": {
        "spouse": "Spouse",
        "child": "Child",
        "parent": "Parent",
        "sibling": "Sibling",
        "other": "Other"
      }
    },
    "idDocument": {
      "type": "file",
      "label": "Upload ID Document",
      "required": true,
      "placeholder": "",
      "description": "Upload a clear scan/photo of your NIC or passport (PDF/JPG/PNG).",
      "defaultValue": "",
      "validation": {},
      "fileOptions": {
        "maxSize": 5242880,
        "allowedExtensions": ["pdf", "jpg", "jpeg", "png"],
        "multiple": false
      }
    },
    "declarationAgreement": {
      "type": "checkbox",
      "label": "I declare that the information provided is true and complete.",
      "required": true,
      "placeholder": "",
      "description": "You must agree before submitting the proposal.",
      "defaultValue": "",
      "validation": {}
    }
  },
  "layout": [
    {
      "text": "Please complete all required fields. Inaccurate information may affect your cover and claim eligibility."
    },
    {
      "divider": true
    },
    {
      "h2": "Personal Information"
    },
    {
      "field": "fullName"
    },
    {
      "field": "dob"
    },
    {
      "field": "gender"
    },
    {
      "field": "maritalStatus"
    },
    {
      "field": "nationalId"
    },
    {
      "field": "mobile"
    },
    {
      "field": "email"
    },
    {
      "field": "address"
    },
    {
      "field": "occupation"
    },
    {
      "field": "annualIncome"
    },
    {
      "divider": true
    },
    {
      "h2": "Health Information"
    },
    {
      "field": "smokerStatus"
    },
    {
      "field": "alcoholUse"
    },
    {
      "divider": true
    },
    {
      "h2": "Coverage Details"
    },
    {
      "field": "sumAssured"
    },
    {
      "field": "policyTermYears"
    },
    {
      "field": "premiumPaymentFrequency"
    },
    {
      "field": "addCriticalIllnessRider"
    },
    {
      "field": "addAccidentalDeathRider"
    },
    {
      "field": "hasExistingPolicies"
    },
    {
      "divider": true
    },
    {
      "h2": "Beneficiary Information"
    },
    {
      "field": "beneficiaryName"
    },
    {
      "field": "beneficiaryRelationship"
    },
    {
      "divider": true
    },
    {
      "h2": "Documents & Declaration"
    },
    {
      "field": "idDocument"
    },
    {
      "field": "declarationAgreement"
    }
  ],
  "localization": {
    "en": {
      "formTitle": "Life Insurance Proposal Form",
      "formDescription": "Apply for comprehensive life insurance cover with optional riders and beneficiary nominations.",
      "fullName.label": "Full Name (as per NIC / Passport)",
      "fullName.placeholder": "e.g. Perera A.B.C.",
      "sumAssured.label": "Requested Sum Assured (LKR)",
      "policyTermYears.label": "Policy Term (Years)",
      "premiumPaymentFrequency.label": "Premium Payment Frequency"
    },
    "si": {
      "formTitle": "ජීවිත රක්ෂණ යෝජනා පත්‍රය",
      "formDescription": "විකල්ප අතිරේක ප්‍රතිලාභ සහ වාරසාධිකයින් නම් කිරීම සමඟ සම්පූර්ණ ජීවිත රක්ෂණ ආවරණයක් සඳහා අයදුම් කරන්න.",
      "fullName.label": "සම්පූර්ණ නම (ජා.හැ./ පස්පෝට් අනුව)",
      "fullName.placeholder": "උදා: පෙරේරා A.B.C.",
      "sumAssured.label": "ඉල්ලෙන ආවරණ (රු.)",
      "policyTermYears.label": "පොලිසි කාලය (වසර)",
      "premiumPaymentFrequency.label": "ප්‍රිමියම් ගෙවීම් අවධිය"
    },
    "ta": {
      "formTitle": "வாழ்க்கை காப்பீட்டு முன்மொழிவு படிவம்",
      "formDescription": "கூடுதல் ரைடர்களும் பயனாளி நியமனங்களும் உடன் முழுமையான வாழ்க்கை காப்பீட்டு பாதுகாப்புக்கு விண்ணப்பிக்கவும்.",
      "fullName.label": "முழுப்பெயர் (தே.அ/ பாஸ்போர்ட் படி)",
      "sumAssured.label": "கோரப்பட்ட காப்பீட்டு தொகை (LKR)",
      "policyTermYears.label": "காப்பீட்டு காலம் (ஆண்டுகள்)"
    }
  }
}
