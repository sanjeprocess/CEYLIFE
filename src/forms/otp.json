    },
    "ta": {
      "otp.dialog.title": "OTP சரிபார்ப்பு",
      "otp.dialog.content": "செலின்கோ லைஃப் டிஜிட்டல் படிவங்களை அணுகியதற்கு நன்றி. தொடர, SMS மூலம் நீங்கள் பெற்ற OTP ஐ உள்ளிடவும்.",
      "otp.dialog.button": "OTP சரிபார்க்க",
      "otp.dialog.inputLabel": "OTP",
