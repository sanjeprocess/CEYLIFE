{
  "metadata": {
    "formVersion": 1,
    "formTitle": "Otp",
    "formDescription": "Form description for Otp",
    "availableLocales": ["en", "si", "ta"],
    "defaultLocale": "en",
    "searchParamsVariables": {
      "cs": "contract_sequence",
      "id": "card_id"
    }
  },
  "otp": {
    "enabled": true,
    "dialog": {
      "title": "OTP Verification",
      "content": "Thank you for accessing the digital forms of Ceylinco Life. In order to proceed ahead, please enter the OTP you received via SMS.",
      "button": "Verify OTP",
      "inputLabel": "OTP",
      "inputPlaceholder": "Enter OTP"
    },
    "verification": {
      "method": "GET",
      "baseUrl": "https://app.workhub24.com",
      "endpoint": "/api/view/MB4EALVIJI66HLKVX6LISPLOZ6HYZL6C/Y5RKJDCXHHOUI7YHMDE27WS7JCSCIZV7",
      "headers": [
        { "name": "Accept", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{$WORKHUB_TOKEN}}" }
      ],
      "queryParams": [
        { "name": "OTP", "value": "{{otp}}" },
        { "name": "Contract_Sequence", "value": "{{contract_sequence}}" },
        { "name": "Card_ID", "value": "{{card_id}}" }
      ],
      "response": {
        "variableMapping": [
          {
            "path": "[0].cLOUReferenceNumber",
            "to": "clou_reference",
            "required": true
          },
          {
            "path": "[0].clientEmail",
            "to": "client_email",
            "required": false
          },
          { "path": "[0].clientName", "to": "client_name", "required": true },
          {
            "path": "[0].clientNumber",
            "to": "client_number",
            "required": false
          },
          { "path": "[0].contactNo1", "to": "contact_1", "required": false },
          { "path": "[0].contactNo2", "to": "contact_2", "required": false },
          {
            "path": "[0].contractNumber",
            "to": "contract_number",
            "required": true
          },
          {
            "path": "[0].questionnaire",
            "to": "questionnaire_type",
            "required": false
          },
          {
            "path": "[0].requestType",
            "to": "request_type",
            "required": false
          },
          {
            "path": "[0].language",
            "to": "preferred_language",
            "required": false
          }
        ]
      }
    }
  },
  "submission": {
    "endpoint": "/api/forms/otp",
    "method": "POST",
    "requiresAccessToken": true
  },
  "fields": {
    "clientName": {
      "type": "text",
      "label": "Client Name",
      "required": true,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Your name as per our records",
      "defaultValue": "{{client_name}}"
    },
    "contractNumber": {
      "type": "text",
      "label": "Contract Number",
      "required": true,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Your contract number",
      "defaultValue": "{{contract_number}}"
    },
    "clouReference": {
      "type": "text",
      "label": "CLOU Reference Number",
      "required": true,
      "placeholder": "Auto-filled after OTP verification",
      "description": "CLOU reference number",
      "defaultValue": "{{clou_reference}}"
    },
    "clientEmail": {
      "type": "email",
      "label": "Email Address",
      "required": false,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Your email address",
      "defaultValue": "{{client_email}}"
    },
    "clientNumber": {
      "type": "text",
      "label": "Client Number",
      "required": false,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Your client number",
      "defaultValue": "{{client_number}}"
    },
    "contactNo1": {
      "type": "tel",
      "label": "Primary Contact Number",
      "required": false,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Your primary contact number",
      "defaultValue": "{{contact_1}}"
    },
    "contactNo2": {
      "type": "tel",
      "label": "Secondary Contact Number",
      "required": false,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Your secondary contact number",
      "defaultValue": "{{contact_2}}"
    },
    "requestType": {
      "type": "text",
      "label": "Request Type",
      "required": false,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Type of request",
      "defaultValue": "{{request_type}}"
    },
    "questionnaireType": {
      "type": "text",
      "label": "Questionnaire Type",
      "required": false,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Questionnaire type",
      "defaultValue": "{{questionnaire_type}}"
    },
    "preferredLanguage": {
      "type": "text",
      "label": "Preferred Language",
      "required": false,
      "placeholder": "Auto-filled after OTP verification",
      "description": "Your preferred language",
      "defaultValue": "{{preferred_language}}"
    },
    "submissionDate": {
      "type": "datetime-local",
      "label": "Submission Date & Time",
      "required": false,
      "placeholder": "Current date and time",
      "description": "Date and time of submission",
      "defaultValue": "{{$now}}"
    }
  },
  "layout": [
    {
      "h2": "Personal Information"
    },
    {
      "field": "clientName"
    },
    {
      "spacer": 10
    },
    {
      "field": "clientEmail"
    },
    {
      "spacer": 20
    },
    {
      "h2": "Contract Details"
    },
    {
      "field": "contractNumber"
    },
    {
      "spacer": 10
    },
    {
      "field": "clouReference"
    },
    {
      "spacer": 10
    },
    {
      "field": "clientNumber"
    },
    {
      "spacer": 20
    },
    {
      "h2": "Contact Information"
    },
    {
      "field": "contactNo1"
    },
    {
      "spacer": 10
    },
    {
      "field": "contactNo2"
    },
    {
      "spacer": 20
    },
    {
      "h2": "Additional Information"
    },
    {
      "field": "requestType"
    },
    {
      "spacer": 10
    },
    {
      "field": "questionnaireType"
    },
    {
      "spacer": 10
    },
    {
      "field": "preferredLanguage"
    },
    {
      "spacer": 10
    },
    {
      "field": "submissionDate"
    },
    {
      "spacer": 30
    },
    {
      "submit": "Submit Form"
    }
  ],
  "localization": {
    "en": {
