      "otp.dialog.content": "Thank you for accessing the digital forms of Ceylinco Life. In order to proceed ahead, please enter the OTP you received via SMS.",
      "otp.dialog.button": "Verify OTP",
      "otp.dialog.inputLabel": "OTP",
      "otp.dialog.inputPlaceholder": "Enter OTP"
    },
